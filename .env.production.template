# ⚠️ IMPORTANT: Create .env.local on Hostinger server
# This file should contain PRODUCTION credentials
# Store it safely - DO NOT upload to git

# Database
DATABASE_URL="your_hostinger_database_url_here"

# Node Environment
NODE_ENV=production
PORT=3000

# JWT Secret (generate a random 32+ character string)
JWT_SECRET="your_secure_random_32_character_string_here"

# API URLs
NEXT_PUBLIC_API_URL="https://aiudaanbootcamp.com"
NEXT_PUBLIC_APP_URL="https://aiudaanbootcamp.com"

# Email Configuration (if using nodemailer)
# SMTP_HOST="your_smtp_host"
# SMTP_PORT="587"
# SMTP_USER="your_email@hostinger.com"
# SMTP_PASS="your_email_password"

# Google (if using OAuth)
# GOOGLE_CLIENT_ID="your_google_client_id"
# GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Other APIs
# API_KEY_1="value"
# API_KEY_2="value"

# Create this file on server by:
# 1. SSH into Hostinger
# 2. cd /home/u739130981/domains/aiudaanbootcamp.com/nodejs/
# 3. nano .env.local
# 4. Paste this content with your actual values
# 5. Press Ctrl+X, then Y, then Enter to save
